---
/**
 * ThemeToggle — light/dark mode switch (session-scoped, dark-first).
 *
 * Storage model (2026-05-04, board directive 22:10 CEST):
 *   - Initial mode: read from sessionStorage["theme"] if present,
 *     else fall back to "dark" (NOT to the OS `prefers-color-scheme`).
 *     Every fresh tab opens in dark.
 *   - On click: toggle light <-> dark, write sessionStorage["theme"],
 *     set `data-theme` on <html>.
 *   - sessionStorage is wiped when the tab/window is closed, so the
 *     persistence is transient ("session only"). No localStorage,
 *     no cookie, no fingerprint surface.
 *
 * Why sessionStorage and not localStorage:
 *   The Austrian TDDDG §25 (and the ePrivacy regime it transposes)
 *   treats localStorage of a non-essential preference as a storage
 *   operation requiring consent. A purely transient, session-scoped
 *   write of an explicit user preference falls into the grey zone
 *   that BfDI guidance and CJEU case law on session persistence
 *   accept without a consent banner. ADR-0030 captures the rationale.
 *
 * FOUC bootstrap:
 *   With the dark-first default, the first paint must already see
 *   `data-theme="dark"` on <html>; otherwise a tab whose previous
 *   session toggled to light would briefly flash dark on reload, and
 *   a tab with no stored value would flash light if any UA picks the
 *   light branch from the `<meta color-scheme>` hint. The bootstrap
 *   lives in `layouts/Base.astro` as a synchronous inline script in
 *   <head> (runs before body render). This component only owns the
 *   click + post-mount sync, not the pre-paint state.
 */
---

<button
  class="theme-toggle"
  type="button"
  aria-label="Toggle light or dark mode"
  data-theme-toggle
>
  <span class="theme-toggle__icon" aria-hidden="true" data-theme-toggle-icon>
    moon
  </span>
</button>

<script is:inline>
  (function () {
    var btn = document.querySelector("[data-theme-toggle]");
    if (!btn) return;
    var icon = btn.querySelector("[data-theme-toggle-icon]");
    var root = document.documentElement;

    function readStored() {
      try {
        var v = sessionStorage.getItem("theme");
        return v === "light" || v === "dark" ? v : null;
      } catch (e) {
        // Storage disabled / SecurityError in some embedded contexts.
        return null;
      }
    }

    function writeStored(theme) {
      try {
        sessionStorage.setItem("theme", theme);
      } catch (e) {
        // Storage disabled — ignore, click still updates the in-page state.
      }
    }

    function setIcon(theme) {
      if (icon) icon.textContent = theme === "light" ? "sun" : "moon";
    }

    // Sync icon to the current theme. The pre-paint bootstrap in
    // Base.astro has already set `data-theme` on <html>; we just read it
    // back. If it is missing for any reason, treat the page as dark
    // (matches the dark-first default).
    var current = root.dataset.theme === "light" ? "light" : "dark";
    setIcon(current);

    btn.addEventListener("click", function () {
      var now = root.dataset.theme === "light" ? "light" : "dark";
      var next = now === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      writeStored(next);
      setIcon(next);
    });
  })();
</script>
