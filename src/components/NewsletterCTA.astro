---
/**
 * NewsletterCTA — newsletter / feed link block.
 *
 * Per ADR-0024 + editorial decision 2026-05-04:
 *   - No own capture, no email input, no tracking pixel.
 *   - External link only.
 *   - Two placements:
 *       variant="inline"  — at end of long-form essay (compact one-liner).
 *       variant="footer"  — site-footer area subscribe block.
 *
 * 2026-05-04 link-audit: the planned Beehiiv subdomain
 * (https://wakirlabs.beehiiv.com) returns 403 / is not reserved. Until the
 * publication is live, link the on-site RSS feed instead. Wording adapted
 * to be honest about the state. Pending Mira-decision on the publishing
 * channel (Beehiiv reservation vs. alternative provider). */

interface Props {
  variant?: "inline" | "footer";
  /** Override the link target. Defaults to the on-site RSS feed. */
  feedUrl?: string;
}

const {
  variant = "inline",
  feedUrl = "/rss.xml",
} = Astro.props;
---

{
  variant === "inline" ? (
    <aside class="newsletter newsletter--compact" aria-label="Newsletter">
      <p class="newsletter__desc">
        This was a long essay. The weekly Field Notes newsletter is in setup —
        for now, follow new posts via the RSS feed.
      </p>
      <a class="newsletter__cta" href={feedUrl}>
        Follow via RSS &rarr;
      </a>
    </aside>
  ) : (
    <aside class="newsletter" aria-label="Newsletter">
      <div class="newsletter__label">Field Notes &mdash; the weekly newsletter</div>
      <p class="newsletter__desc">
        Field Notes will publish ~600 words every Thursday once the newsletter
        infrastructure is live. Until then, the RSS feed carries every new
        post on this site.
      </p>
      <a class="newsletter__cta" href={feedUrl}>
        Follow via RSS &rarr;
      </a>
    </aside>
  )
}
