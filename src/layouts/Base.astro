---
import "../styles/global.css";
import "../styles/components.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  /** Hide the long-form max-width wrapper (used by index/about which set their own). */
  bare?: boolean;
  /** Page type for OpenGraph / JSON-LD. "website" for landing/index, "article" for essays. */
  ogType?: "website" | "article";
  /** ISO date for Article schema (essays only). */
  publishedTime?: string;
  /** Optional override for og:image; falls back to default share-card. */
  ogImage?: string;
}

const {
  title,
  description = "Wakir Labs — accountable multi-agent systems, a framework for AI-first organizations.",
  lang = "en",
  bare = false,
  ogType = "website",
  publishedTime,
  ogImage,
} = Astro.props;

const isEn = lang === "en";
const path = Astro.url.pathname;
const altPath = isEn ? `/de${path}`.replace(/\/+$/, "/") : path.replace(/^\/de/, "") || "/";

// EN <-> DE pages that have a real translated counterpart on disk. Used to
// decide whether to emit hreflang / og:locale:alternate. Adding a hreflang
// for a non-existent translation misleads search engines and (with the CF
// Pages 404-fallback-to-index behaviour) misleads crawlers into indexing
// the home page as if it were the translation. Keep this set in sync with
// `src/pages/de/`.
//
// Path values are EN-side, with leading slash and trailing slash, exactly
// as `Astro.url.pathname` reports them.
const dePagesAvailable = new Set<string>([
  "/",
  "/about/",
  "/verify/",
  "/404/",
  "/impressum/",
  "/datenschutz/",
]);

// Normalise the EN-side path key (strip /de prefix when on DE page).
const enSidePath = isEn ? path : (path.replace(/^\/de/, "") || "/");
const hasAlternate = dePagesAvailable.has(enSidePath);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogLocale = isEn ? "en_US" : "de_DE";
const ogLocaleAlt = isEn ? "de_DE" : "en_US";
// Default OG image is the existing brand cover (1500x500). Sufficient until a
// dedicated OG generator lands (Phase 2; see report 2026-05-04-astro-performance-polish-done.md).
const ogImageUrl = new URL(
  ogImage ?? "/brand/cover-wakir-labs-1500x500-light.png",
  Astro.site,
).toString();

// Article-schema JSON-LD payload (only emitted when ogType === "article").
const articleJsonLd = ogType === "article"
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description,
      url: canonicalUrl,
      inLanguage: lang,
      author: { "@type": "Organization", name: "Wakir Labs", url: "https://wakirlabs.com/" },
      publisher: {
        "@type": "Organization",
        name: "Wakir Labs",
        url: "https://wakirlabs.com/",
        logo: {
          "@type": "ImageObject",
          url: new URL("/brand/avatar-wakir-512-light.png", Astro.site).toString(),
        },
      },
      ...(publishedTime ? { datePublished: publishedTime } : {}),
      image: ogImageUrl,
    }
  : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph (Facebook/LinkedIn/Slack/Discord previews) -->
    <meta property="og:site_name" content="Wakir Labs" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    {hasAlternate && (
      <meta property="og:locale:alternate" content={ogLocaleAlt} />
    )}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- hreflang for EN/DE pairs. The EN<->DE alternate is only emitted when
         a real translated page exists on disk (see `dePagesAvailable`).
         Otherwise we'd point search engines at the CF-Pages 404-fallback,
         which serves the home page with HTTP 200. -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {hasAlternate && (
      <link
        rel="alternate"
        hreflang={isEn ? "de" : "en"}
        href={new URL(altPath, Astro.site).toString()}
      />
    )}
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site).toString()} />

    {articleJsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(articleJsonLd)}
      />
    )}

    <!-- Preload critical fonts (per brand-spec §2.1) -->
    <link
      rel="preload"
      href="/fonts/source-serif-4-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>

    {/* Theme bootstrap (2026-05-04, board directive 22:10 CEST). Dark is the
        deterministic default for every fresh tab; the OS `prefers-color-scheme`
        is no longer consulted. This inline script runs before body render so
        that `data-theme` is present on <html> at first paint, preventing the
        FOUC that the dark-default would otherwise produce on a tab whose
        previous session was light (or any UA that defaults its initial paint
        to light from the `<meta color-scheme>` hint). The toggle component
        owns the click handler and only writes sessionStorage. ADR-0030
        follow-up still owns the cookie-banner decision. */}
    <script is:inline>
      (function () {
        try {
          var v = sessionStorage.getItem("theme");
          var theme = (v === "light" || v === "dark") ? v : "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a href={isEn ? "/" : "/de/"} class="site-header__brand" aria-label="Wakir Labs home">
          Wakir Labs
        </a>
        <nav class="site-header__nav" aria-label="Primary">
          <a href={isEn ? "/about/" : "/de/about/"}>{isEn ? "about" : "über"}</a>
          <a href={isEn ? "/verify/" : "/de/verify/"}>verify</a>
          <span class="lang-toggle" aria-label="Language">
            <a href="/" {...(isEn ? { "aria-current": "page" } : {})}>en</a>
            &middot;
            <a href="/de/" {...(!isEn ? { "aria-current": "page" } : {})}>de</a>
          </span>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <nav class="site-footer__nav" aria-label="Footer">
          <a href={isEn ? "/about/" : "/de/about/"}>About</a>
          <a href={isEn ? "/verify/" : "/de/verify/"}>Verify</a>
          <a href="https://github.com/wakir-labs" rel="external">GitHub</a>
          {/* 2026-05-04 link-audit: Field Notes link removed —
              wakirlabs.beehiiv.com is not reserved (403). Re-add once the
              publishing channel is live. RSS stays as the working feed. */}
          <a href="/rss.xml">RSS</a>
        </nav>
        {/* Legal nav (ADR-0030, 2026-05-05). Separate <nav> so that screen
            readers announce it as a distinct landmark from the primary
            footer nav. DE-side links to the /de/ mirrors. Reuses the
            existing site-footer__nav styling for visual consistency. */}
        <nav class="site-footer__nav" aria-label={isEn ? "Legal" : "Rechtliches"}>
          <a href={isEn ? "/impressum/" : "/de/impressum/"}>{isEn ? "Imprint" : "Impressum"}</a>
          <a href={isEn ? "/datenschutz/" : "/de/datenschutz/"}>{isEn ? "Privacy" : "Datenschutz"}</a>
        </nav>
        <p>&copy; {new Date().getFullYear()} Wakir Labs &middot; Apache 2.0 where applicable.</p>
      </div>
    </footer>
  </body>
</html>
